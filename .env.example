# IPP — Infrastructure Platform Portal
# Master environment file. Copy to .env and edit before running bootstrap.sh.
# All values below are safe defaults for local KIND development.
# DO NOT commit .env with real secrets to any repository.

# ── Demo mode ─────────────────────────────────────────────────────────────────
# true  → Backstage uses mockData.ts; AIOps returns pre-seeded demo responses
# false → Backstage calls live cluster APIs; AIOps queries real collectors
DEMO_MODE=true

# ── Backstage ─────────────────────────────────────────────────────────────────
BACKSTAGE_BASE_URL=http://localhost:3000
BACKSTAGE_BACKEND_URL=http://localhost:7007
BACKSTAGE_POSTGRES_USER=backstage
BACKSTAGE_POSTGRES_PASSWORD=backstage-demo-local
BACKSTAGE_POSTGRES_DB=backstage

# ── AIOps / LLM ───────────────────────────────────────────────────────────────
# Set ANTHROPIC_API_KEY to have AIOps agents use Anthropic Claude instead of
# the local Ollama model. Leave it blank to keep the fully local/offline setup
# (Ollama runs on the host machine — no API key required in that case).
#
# On a running cluster, switch providers instantly (no key edits/rebuild) with:
#   make aiops-use-claude   |   make aiops-use-local   |   make aiops-llm-status
# (these toggle the ANTHROPIC_ENABLED flag in the aiops-config ConfigMap directly —
# the API key stays configured either way; ANTHROPIC_ENABLED below only applies to
# non-cluster / local `uvicorn` runs, where it's read straight from this .env)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_ENABLED=true

# Local LLM fallback — used automatically whenever Anthropic is disabled or unconfigured.
# Pull the model first: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
AIOPS_AGENT_MODE=local
LLM_TIMEOUT=30.0
LLM_MAX_RETRIES=2

# AIOps signal sources (default: in-cluster service DNS)
# For local development with DEMO_MODE=true these are not contacted.
PROMETHEUS_URL=http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090
ARGOCD_URL=http://argocd-server.argocd.svc.cluster.local:80
OPENCOST_URL=http://opencost.opencost.svc.cluster.local:9090
HUBBLE_URL=http://hubble-relay.kube-system.svc.cluster.local:4245
SPIRE_SERVER_URL=http://spire-server.spire.svc.cluster.local:8081

# ── Grafana proxy auth (used by Backstage /grafana/api proxy) ─────────────────
# Value is base64(username:password). The example below is local-demo-only.
# Generate for production: echo -n "user:password" | base64
# NEVER commit a real production value here or in app-config.yaml.
GRAFANA_BASIC_AUTH=YWRtaW46Z3JhZmFuYS1kZW1vLWxvY2FsLTIwMjQ=

# ── ArgoCD ────────────────────────────────────────────────────────────────────
ARGOCD_ADMIN_PASSWORD=argocd-demo-local
ARGOCD_SERVER_URL=http://argocd.ipp.local

# ── GitHub (optional — for Backstage SCM catalog integration) ─────────────────
# Leave blank to use the local file-based catalog only.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# ── LangSmith tracing (optional — leave blank for fully local operation) ──────
# Set LANGCHAIN_TRACING_V2=true and supply a real key to enable cloud tracing.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ipp-aiops-demo
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Demo credentials (non-secret, local only) ─────────────────────────────────
DEMO_AUTH_SECRET=demo-auth-secret-local

export GITHUB_PAT="your-github-pat-here" # GitHub Personal Access Token (repo + workflow scopes)
export GITHUB_OWNER="https://github.com/amitabhmanish13/" # GitHub org or username 
export GITHUB_REPO="IPP_Demoselfservice" # The repo name
